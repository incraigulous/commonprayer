{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/liturgy/**",
              "components/navigation/**",
              "ui_kits/common-prayer/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Goudy Initials|Cormorant Garamond|EB Garamond))/i]",
        "message": "Font not provided by the design system. Available: Goudy Initials, Cormorant Garamond, EB Garamond."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|as|href|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, as, href, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|glyph|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: variant, title, glyph, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|eyebrow|title|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, eyebrow, title, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|help|error|required|multiline|rows|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, help, error, required, multiline, rows."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='IlluminatedInitial'] > JSXAttribute > JSXIdentifier[name!=/^(?:letter|variant|boxed|children|key|ref|className|style|children)$/]",
        "message": "<IlluminatedInitial> doesn't accept that prop. Declared props: letter, variant, boxed, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrnamentalDivider'] > JSXAttribute > JSXIdentifier[name!=/^(?:glyph|tone|key|ref|className|style|children)$/]",
        "message": "<OrnamentalDivider> doesn't accept that prop. Declared props: glyph, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrnamentalDivider'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gilt|rubric)$/]",
        "message": "<OrnamentalDivider> tone must be one of 'gilt' | 'rubric'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Rubric'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|center|as|children|key|ref|className|style|children)$/]",
        "message": "<Rubric> doesn't accept that prop. Declared props: variant, center, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Scripture'] > JSXAttribute > JSXIdentifier[name!=/^(?:cite|variant|mark|children|key|ref|className|style|children)$/]",
        "message": "<Scripture> doesn't accept that prop. Declared props: cite, variant, mark, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Scripture'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:quiet|illuminated)$/]",
        "message": "<Scripture> variant must be one of 'quiet' | 'illuminated'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|level|rule|center|as|children|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, level, rule, center, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='TypeScale'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|key|ref|className|style|children)$/]",
        "message": "<TypeScale> doesn't accept that prop. Declared props: value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='VersicleLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:by|text|response|key|ref|className|style|children)$/]",
        "message": "<VersicleLine> doesn't accept that prop. Declared props: by, text, response."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
